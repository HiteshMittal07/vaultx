# ─── Application ─────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for OpenGraph metadata)
NEXT_PUBLIC_APP_URL=https://vaultx.finance

# ─── Privy Auth ──────────────────────────────────────────────────────────────
# Get these from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
APP_SECRET=your-privy-app-secret

# ─── Account Abstraction (Biconomy / EIP-7702) ────────────────────────────────
# Quorum Key ID for the EIP-7702 authorization signer (from Privy dashboard)
NEXT_PUBLIC_AUTHORIZATION_KEY_ID=your-quorum-key-id

# ECDSA private key (PEM format) for signing EIP-7702 authorizations
AUTHORIZATION_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
...your key here...
-----END EC PRIVATE KEY-----"

# Hex private key (0x...) for the relay wallet that pays gas for UserOps
PRIVATE_KEY=0x...your-relay-wallet-private-key...

# ─── Blockchain RPC ───────────────────────────────────────────────────────────
# Server-side RPC endpoint (Alchemy, Infura, etc.)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Client-side RPC endpoint (can be the same or a public fallback)
NEXT_PUBLIC_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vaultx?retryWrites=true&w=majority

# ─── Internal API Security ───────────────────────────────────────────────────
# Secret for internal-only endpoints (offline agent execution)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=your-internal-api-key

# Secret for cron endpoint authentication (GitHub Actions / Vercel Cron)
# Generate with: openssl rand -base64 32
# Add to GitHub Secrets as CRON_SECRET
CRON_SECRET=your-cron-secret
